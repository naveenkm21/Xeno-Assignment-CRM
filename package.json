{
  "name": "xeno-copilot",
  "version": "0.1.0",
  "private": true,
  "description": "AI-native mini CRM — chat-first agentic copilot for reaching shoppers",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter=./apps/* run dev",
    "dev:web": "pnpm --filter=@xeno/web dev",
    "dev:channel": "pnpm --filter=@xeno/channel dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "db:push": "pnpm --filter=@xeno/db push",
    "db:seed": "pnpm --filter=@xeno/db seed",
    "db:studio": "pnpm --filter=@xeno/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
