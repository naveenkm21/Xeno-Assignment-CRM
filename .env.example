# ============================================================================
# Xeno Copilot — environment variables
# Copy this to .env at the repo root, fill in your free-tier credentials.
# Every workspace loads from the same repo-root .env.
# ============================================================================

# --- Database (Neon — free Postgres) ---
# Create a project at https://neon.tech and copy the pooled connection string.
DATABASE_URL="postgresql://user:password@host.neon.tech/xeno?sslmode=require"

# --- LLM (Groq — free tier, get key at https://console.groq.com) ---
GROQ_API_KEY="gsk_..."
GROQ_PLANNER_MODEL="llama-3.3-70b-versatile"
GROQ_DRAFTER_MODEL="llama-3.1-8b-instant"

# --- Auth (Clerk — free tier) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# --- Queue + cache (Upstash Redis — free tier) ---
REDIS_URL="rediss://default:password@host.upstash.io:6379"
UPSTASH_REDIS_REST_URL="https://host.upstash.io"
UPSTASH_REDIS_REST_TOKEN="..."

# --- Service URLs ---
WEB_BASE_URL="http://localhost:3000"
CHANNEL_BASE_URL="http://localhost:4000"

# --- Shared HMAC secret for receipt callbacks (channel-stub → web) ---
# Generate a long random string. Both services must agree.
CHANNEL_WEBHOOK_SECRET="change-me-to-a-long-random-string"
